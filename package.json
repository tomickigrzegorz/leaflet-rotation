{
  "name": "@tomickigrzegorz/leaflet-rotate",
  "version": "0.2.1",
  "description": "Leaflet map rotation engine: bearing, heading-up, touch/drag/keyboard rotate, compass control.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/leaflet-rotate.umd.js",
  "module": "dist/leaflet-rotate.esm.js",
  "unpkg": "dist/leaflet-rotate.umd.min.js",
  "jsdelivr": "dist/leaflet-rotate.umd.min.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/leaflet-rotate.esm.js",
      "require": "./dist/leaflet-rotate.umd.js"
    },
    "./css": "./dist/leaflet-rotate.css"
  },
  "sideEffects": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c && node scripts/copy-assets.mjs",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "leaflet": ">=1.9 <2"
  },
  "devDependencies": {
    "rollup": "^4.62.0",
    "@rollup/plugin-terser": "^1.0.0"
  },
  "license": "MIT",
  "author": "Grzegorz Tomicki",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomickigrzegorz/leaflet-rotate.git"
  },
  "keywords": [
    "leaflet",
    "rotate",
    "rotation",
    "bearing",
    "heading",
    "compass",
    "map"
  ]
}
